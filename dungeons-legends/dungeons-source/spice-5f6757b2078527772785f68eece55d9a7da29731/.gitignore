# Visual Studio 2015 user specific files
.vs/

# Visual Studio 2015 database file
*.VC.db

# Debugger files
*.pdb

# Logs
*.log
*.tlog

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*

# Builds
Build/*

# Don't ignore icon files in Build
!Build/**/*.ico

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/AssetRegistryCache/*
Intermediate/Build/*
Intermediate/Config/*
Intermediate/ReimportCache/*
Intermediate/Staging/*
Intermediate/CachedAssetRegistry.bin

# Cache files for the editor to use
DerivedDataCache/*

# Deps
Deps/Dependencies
!Deps/Dependencies/*.vcxproj
!Deps/Dependencies/*.vcxproj.filters
!Deps/Dependencies/*.vcxproj.user
Deps/x64
Deps/x86