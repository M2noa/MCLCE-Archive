      "minecraft:behavior.melee_attack": {
        "priority": 3,
        "speed_multiplier": 1.15,
        "track_target": false
      },
	  "badger:behavior.idle": {
        "priority": 1000,
        "probability": 0.99,
        "max_dist": 8,
        "speed_multiplier": 0.8
      },
      "minecraft:physics": {},
      "minecraft:on_target_escape": {
        "event": "minecraft:stop_exploding",
        "target": "self"
      }
    },
    "events": {

      "apply_buffs": {
        "add":{ "component_groups": [
          "check_for_buffs",
          "minecraft:horny_for_spiders"
        ]}
      },
      "ignore_buffs": {
        "remove":{ "component_groups": [
          "check_for_buffs"
        ]}
      },

      "apply_magmablood": {
        "add": { "component_groups": [
          "magmablood"
        ]}
      },

      "minecraft:get_horny": {
        "add": { "component_groups": [
          "minecraft:horny_for_spiders"
        ]}

      },
      "minecraft:turn_off": {
        "remove": { "component_groups": [
          "minecraft:horny_for_spiders"
        ]}
      },

      "minecraft:start_exploding_forced": {
        "sequence": [
          {
            "filters": {
              "test": "has_component",
              "operator": "!=",
              "value": "minecraft:is_charged"
            },
            "add": {
              "component_groups": [
                "minecraft:forced_exploding"
              ]
            }
          },
          {
            "filters": {
              "test": "has_component",
              "value": "minecraft:is_charged"
            },
            "add": {
              "component_groups": [
                "minecraft:forced_charged_exploding"
              ]
            }
          }
        ]
      },
      "minecraft:start_exploding": {
        "sequence": [
          {
            "filters": {
              "test": "has_component",
              "operator": "!=",
              "value": "minecraft:is_charged"
            },
            "add": {
              "component_groups": [
                "minecraft:exploding"
              ]
            }
          },
          {
            "filters": {
              "test": "has_component",
              "value": "minecraft:is_charged"
            },
            "add": {
              "component_groups": [
                "minecraft:charged_exploding"
              ]
            }
          }
        ]
      },
      "minecraft:stop_exploding": {
        "remove": {
          "component_groups": [
            "minecraft:exploding"
          ]
        }
      },
      "minecraft:become_charged": {
        "remove": {
          "component_groups": [
            "minecraft:exploding"
          ]
        },
        "add": {
          "component_groups": [
            "minecraft:charged_creeper"
          ]
        }
      },
			"minecraft:entity_spawned": {
				"add": {
					"component_groups": [
						"minecraft:stats_normal"
					]
				}
			},
			"minecraft:enlargeable_grow": {
				"remove": {
					"component_groups": [
						"minecraft:stats_normal"
					]
				},
				"add": {
					"component_groups": [
						"minecraft:stats_giant"
					]
				}
			},
			"minecraft:enlargeable_shrink": {
				"remove": {
					"component_groups": [
						"minecraft:stats_giant"
					]
				},
				"add": {
					"component_groups": [
						"minecraft:stats_normal"
					]
				}
			}
