{
  "minecraft:entity": {
    "format_version": "1.2.0",
    "component_groups": {
			"minecraft:stats_normal": {
				"minecraft:scale": {
					"value": 1.0
				},
				"minecraft:health": {
					"value": 16,
					"max": 16
				},
				"minecraft:attack": {
					"damage": 3
				}
			},
			"minecraft:stats_giant": {
				"minecraft:scale": {
					"value": 4.0
				},
				"minecraft:health": {
					"value": 48,
					"max": 48
				},
				"minecraft:attack": {
					"damage": 9
				}
			},
      "minecraft:exploding": {
        "minecraft:explode": {
          "fuseLength": 1.5,
          "fuseLit": true,
          "power": 4,
          "causesFire": false,
          "destroyAffectedByGriefing": true,
          "structureDamageMultiplier": 1,
		      "depthLimit": 0

        }
      },
      "check_for_buffs": {
				"minecraft:structure_prox_trigger": {
					"structure_filters": {
						"all_of": [{
							"test": "is_structure_same_team",
							"subject": "other"
						},{
							"test": "is_structure_name",
							"subject": "other",
							"value": "placeable_magmablood"
						}]
					},
					"opeartor": "and",
					"filters": {
						"all_of": [{
							"test": "has_component",
							"operator": "not",
							"subject": "self",
							"value": "magmablood"
						}]
					},
					"event": "apply_magmablood"
				}
			},

			"magmablood": {
				"minecraft:behavior.spawn_block_on_death": {
					"block_name": "flowing_lava",
					"offset": [0.0, 0.0, 0.0],
					"duration": 5.0
				}
			},
      "minecraft:charged_creeper": {
        "minecraft:is_charged": {}
      },
      "minecraft:charged_exploding": {
        "minecraft:explode": {
          "fuseLength": 1.5,
          "fuseLit": true,
          "power": 6,
          "causesFire": false,
          "destroyAffectedByGriefing": true,

		  "depthLimit": 0
        }
      },
      "minecraft:forced_exploding": {
        "minecraft:target_nearby_sensor": {},
        "minecraft:explode": {
          "fuseLength": 1.5,
          "fuseLit": true,
          "power": 3,
          "causesFire": false,
          "destroyAffectedByGriefing": true,

		  "depthLimit": 0

        },
        "minecraft:on_target_escape": {}
      },
      "minecraft:forced_charged_exploding": {
        "minecraft:target_nearby_sensor": {},
        "minecraft:explode": {
          "fuseLength": 1.5,
          "fuseLit": true,
          "power": 6,
          "causesFire": false,
          "destroyAffectedByGriefing": true,

		  "depthLimit": 0
        },
        "minecraft:on_target_escape": {}
      },
        "minecraft:horny_for_spiders": {
          "minecraft:behavior.combine_with_target": {
            "priority": 4,
            "structure_types": [{
              "filters": { "test": "is_structure_name", "value": "placeable_mob_combiner" }
            }],
            "entity_types": [{
              "filters": { "all_of": [
                {"any_of":[
                  {"all_of":[
                    {"test": "is_family", "subject": "other", "value": "wolf"},
                    {"test": "is_on_team", "subject": "self", "value": "blue"},
                    {"test": "is_on_team", "subject": "other", "value": "blue"}
                  ]},
                  {"all_of":[
                    {"test": "is_family", "subject": "other", "value": "wolf"},
                    {"test": "is_on_team", "subject": "self", "value": "wild"},
                    {"test": "is_on_team", "subject": "other", "value": "wild"}
                  ]},
                  {"all_of":[
                    {"test": "is_family", "subject": "other", "value": "wolf"},
                    {"test": "is_on_team", "subject": "self", "value": "red"},
                    {"test": "is_on_team", "subject": "other", "value": "red"}
                  ]},
                  {"all_of":[
                    {"test": "is_family", "subject": "other", "value": "slime"},
                    {"test": "is_on_team", "subject": "self", "value": "blue"},
                    {"test": "is_on_team", "subject": "other", "value": "blue"}
                  ]},
                  {"all_of":[
                    {"test": "is_family", "subject": "other", "value": "slime"},
                    {"test": "is_on_team", "subject": "self", "value": "wild"},
                    {"test": "is_on_team", "subject": "other", "value": "wild"}
                  ]},
                  {"all_of":[
                    {"test": "is_family", "subject": "other", "value": "slime"},
                    {"test": "is_on_team", "subject": "self", "value": "red"},
                    {"test": "is_on_team", "subject": "other", "value": "red"}
                  ]},
                  {"all_of":[
                    {"test": "is_family", "subject": "other", "value": "spider"},
                    {"test": "is_on_team", "subject": "self", "value": "blue"},
                    {"test": "is_on_team", "subject": "other", "value": "blue"}
                  ]},
                  {"all_of":[
                    {"test": "is_family", "subject": "other", "value": "spider"},
                    {"test": "is_on_team", "subject": "self", "value": "wild"},
                    {"test": "is_on_team", "subject": "other", "value": "wild"}
                  ]},
                  {"all_of":[
                    {"test": "is_family", "subject": "other", "value": "spider"},
                    {"test": "is_on_team", "subject": "self", "value": "red"},
                    {"test": "is_on_team", "subject": "other", "value": "red"}
                  ]}
                ]}
              ]}
            }]
          }
        }

    },
    "components": {
      "minecraft:identifier": {
        "id": "minecraft:creeper"
      },
      "minecraft:structure_sensor": {
				"on_proximity": {
