              "test": "is_family",
              "subject": "other",
              "value": "lightning"
            },
            "event": "minecraft:become_charged"
          },
          "deals_damage": false
        }
      ],
      "minecraft:target_nearby_sensor": {
        "inside_range": 1.5,
        "outside_range": 20.0,
        "on_inside_range": {
          "event": "minecraft:start_exploding",
          "target": "self"
        },
        "on_outside_range": {
          "event": "minecraft:stop_exploding",
          "target": "self"
        }
      },
      "minecraft:interact": {
        "on_interact": {
          "filters": {
            "all_of": [
              {
                "test": "is_family",
                "subject": "other",
                "value": "player"
              },
              {
                "test": "has_equipment",
                "domain": "hand",
                "subject": "other",
                "value": "flint_and_steel"
              },
              {
                "test": "has_component",
                "operator": "!=",
                "value": "minecraft:explode"
              }
            ]
          },
          "event": "minecraft:start_exploding_forced",
          "target": "self"
        },
        "hurt_item": 1,
        "swing": true,
        "play_sounds": "ignite",
