{
  "minecraft:entity": {
    "format_version": "1.2.0",

    "component_groups": {
      "minecraft:slime_large": {
        "minecraft:collision_box": {
          "width": 1.00,
          "height": 1.00
        },
        "minecraft:health": {
          "value": 16,
          "max": 16
        },
        "minecraft:movement": {
          "value": 0.6
        },
        "minecraft:attack": {
          "damage": 4
        },
        "minecraft:rideable": {
          "seat_count": 1,
          "family_types": [
            "zombie",
            "Creeper",
            "witch",
            "skeleton"
          ],
          "seats": {
            "position": [ 0.0, 0.54, 0.0 ]
          }
        }
      },
      "minecraft:slime_medium": {
        "minecraft:collision_box": {
          "width": 0.5,
          "height": 0.5
        },
        "minecraft:health": {
          "value": 4,
          "max": 4
        },
        "minecraft:movement": {
          "value": 0.4
        },
        "minecraft:attack": {
          "damage": 2
        },
        "minecraft:structure_sensor": {
        },
        "minecraft:rideable": {
          "seat_count": 1,
          "family_types": [
            "creeper",
            "witch"
          ],
          "seats": {
            "position": [ 0.0, 0.54, 0.0 ]
          }
        }
      },
      "minecraft:slime_small": {
        "minecraft:collision_box": {
          "width": 0.25,
          "height": 0.25
        },
        "minecraft:health": {
          "value": 1,
          "max": 1
        },
        "minecraft:movement": {
          "value": 0.3
        },
        "minecraft:attack": {
          "damage": 1
        },
        "minecraft:loot": {
          "table": "loot_tables/entities/slime.json"
        }
      },
      "minecraft:slime_calm": {
        "minecraft:movement.jump": {
          "jump_delay": [ 0.5, 1.5 ]
        }
      },
      "minecraft:slime_aggressive": {
        "minecraft:movement.jump": {
          "jump_delay": [ 0.16, 0.5 ]
        }
      },
      "check_for_buffs": {
				"minecraft:structure_prox_trigger": {
					"structure_filters": {
						"all_of": [{
							"test": "is_structure_same_team",
							"subject": "other"
						},{
							"test": "is_structure_name",
							"subject": "other",
							"value": "placeable_magmablood"
						}]
					},
					"opeartor": "and",
					"filters": {
						"all_of": [{
							"test": "has_component",
							"operator": "not",
							"subject": "self",
							"value": "magmablood"
						}]
					},
					"event": "apply_magmablood"
				}
			},

			"magmablood": {
				"minecraft:behavior.spawn_block_on_death": {
					"block_name": "flowing_lava",
					"offset": [0.0, 0.0, 0.0],
					"duration": 5.0
				}
			}
    },
    "components": {
      "minecraft:identifier": {
        "id": "minecraft:slime"
      },
      "minecraft:type_family": {
        "family": [ "slime", "monster" ]
      },
      "minecraft:breathable": {
        "totalSupply": 10,
        "suffocateTime": 1
      },
      "minecraft:navigation.walk": {
        "can_float": true,
        "avoid_water": false
      },
	  "minecraft:jump.static": {
      },
      "minecraft:can_climb": {
      },
      "minecraft:movement.jump": {
        "jump_delay": [ 0.5, 1.5 ]
      },
      "minecraft:on_target_acquired": {
        "event": "minecraft:become_aggressive",
        "target": "self"
      },
      "minecraft:on_target_escape": {
        "event": "minecraft:become_calm",
        "target": "self"
      },
      "minecraft:nameable": {
      },
      "minecraft:behavior.desire_position": {
        "priority": 7
      },
      "minecraft:behavior.slime_attack": {
        "priority": 3
      },
	  "minecraft:behavior.melee_attack": {
		"priority": 4,
		"target_dist": 1.0,
		"track_target": true,
		"reach_multiplier": 1.0
		},
      "minecraft:behavior.slime_random_direction": {
        "priority": 5
      },
      "minecraft:behavior.slime_keep_on_jumping": {
        "priority": 6
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "entity_types": [
          {
            "filters": {
              "any_of": [
				{
				  "all_of": [
				  {
					"test": "is_on_team",
					"subject": "self",
					"value": "wild"
				  },
				  {
					"test": "is_on_team",
					"subject": "other",
					"operator": "not",
					"value": "wild"
				  }
				  ]
				},
				{
				  "all_of": [
				  {
					"test": "is_on_team",
					"subject": "self",
					"value": "red"
				  },
				  {
					"test": "is_on_team",
					"subject": "other",
					"operator": "not",
					"value": "red"
				  }
				  ]
				},
				{
				  "all_of": [
				  {
					"test": "is_on_team",
					"subject": "self",
					"value": "blue"
				  },
				  {
					"test": "is_on_team",
					"subject": "other",
					"operator": "not",
					"value": "blue"
				  }
				  ]
				}
              ]
            },
            "max_dist": 20
          }
        ],
        "must_see": true
      },
      "minecraft:behavior.desire_direction": {
        "priority": 8
      },
      "minecraft:physics": {
      }
    },

    "minecraft:structure_sensor": {
      "on_proximity": {
        "event": "apply_buffs"
      },
      "on_leave": {
        "event": "ignore_buffs"
      }
    },

    "events": {
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": [
            "minecraft:slime_calm"
          ]
        }
      },
      "minecraft:become_calm": {
        "add": {
          "component_groups": [
            "minecraft:slime_calm"
          ]
        }
      },
      "minecraft:become_aggressive": {
        "add": {
          "component_groups": [
            "minecraft:slime_aggressive"
          ]
        }
      },
      "apply_buffs": {
        "add":{ "component_groups": [
          "check_for_buffs"
        ]}
      },
      "ignore_buffs": {
        "remove":{ "component_groups": [
          "check_for_buffs"
        ]}
      },

      "apply_magmablood": {
        "add": { "component_groups": [
          "magmablood"
        ]}
      }
    }
  }
}