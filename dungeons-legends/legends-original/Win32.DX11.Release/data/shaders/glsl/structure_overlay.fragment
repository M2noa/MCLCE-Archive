// __multiversion__
// This signals the loading code to prepend either #version 100 or #version 300 es as apropriate.

#include "shaders/fragmentVersionSimple.h"

#include "shaders/uniformShaderConstants.h"
#include "shaders/uniformPerFrameConstants.h"

varying vec2 uv0;

void main()
{
	vec4 color = CURRENT_COLOR;
	color.a = 0.1;

	gl_FragColor = color;

#if defined(FORCE_DEPTH_ZERO) && __VERSION__ >= 300
	gl_FragDepth = 0.0;
#endif
}
