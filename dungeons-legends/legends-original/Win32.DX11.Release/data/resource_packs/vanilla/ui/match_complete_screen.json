{
  "namespace": "match_complete",

  // Base button //

  "a_button_panel": {
    "type": "panel",
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "size": [ "100%c", 26 ],
    "offset": [ 0, "-17.75%" ],
    "controls": [
      {
        "gamepad_helper_a@common.gamepad_helper_a": {
          "$icon_text_color": "$gamepad_button_generic_text_color",
          "$icon_description_bind": "controller.buttonTip.select",
          "$icon_description_bind_type": "none"
        }
      }
    ]
  },

  // Screen //
  "match_complete_screen@common.base_screen": {
    "$screen_content": "match_complete.screen_content",
    "$screen_bg_content": "match_complete.background_gradient"
  },

  "screen_content": {
    "type": "panel",
    "controls": [
      {
        "result_label": {
          "type": "label",
          "color": "$death_text_color",
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "offset": [ 0, "25%" ],
          "text": "#matchResultText",
          "shadow": true,
          "font_size": "large",
          "bindings": [
            {
              "binding_name": "#matchResultText"
            }
          ]
        }
      },
      {
        "video_button@common_buttons.light_text_button": {
          "size": [ "25%", 26 ],
          "$button_text": "match_complete_screen.play_video",
          "anchor_from": "center",
          "anchor_to": "right_middle",
          "offset": [ -10, 13 ],
          "$pressed_button_name": "button.video_button"
        }
      },
      {
        "main_menu_button@common_buttons.light_text_button": {
          "size": [ "25%", 26 ],
          "$button_text": "deathScreen.quit",
          "anchor_from": "center",
          "anchor_to": "left_middle",
          "offset": [ 10, 13 ],
          "$pressed_button_name": "button.main_menu_button",
          "variables": [
            {
              "requires": "$is_secondary_client",
              "$button_text": "deathScreen.quit.secondaryClient"
            }
          ]
        }
      },
      {
        "select_button@match_complete.a_button_panel": {}
      }
    ]
  },

  "background_gradient": {
    "type": "custom",
    "renderer": "gradient_renderer",
    "color1": [ 1, 1, 1, 0.33 ],
    "color2": [ 0, 0, 0, 0.33 ],
    "ignored": "$is_holographic"
  }
}