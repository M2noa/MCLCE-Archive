  //////////////////////////////////// Follow Cameras
  //"follow_fov70_d10"
  "follow_camera0_UNUSED": {
    //This is the distance of the camera from Steve.
    "distance": 10,

    //This is the tranaslation offset of the "Badger Fixed" and "Badger Follow" cameras.
    "offset": [0.0, 0.0, 0.0],

    //This is the downward angle the camera will try to approach.
    "pitch": 40.0,

    //This is the maximum downward angle the player can look at (MC default is -90.0).
    "pitch_min": 0.0,

    //This is the maximum upward angle the player can look at (MC default is 90.0).
    "pitch_max": 85.0,

    //This is the downard angle that Steve faces in the "Badger Follow" and "Badger Orbit" cameras.
    "head_pitch": 35.0,

    //This is the FOV that this camera will use (overrides the default value)
    "fov": 70.0,

    //Below are a bunch of tweaks for manipulating the follow camera
    // +/- max angle in degrees per frame that the camera offset can swing about the player
    "follow_clamp": 1.0,
    // The fractional rate per frame that the swing (from above) rate to zero
    "follow_rate": 1,
    // The fractional rate per second that the camera tries to get behind the player (0.1 == 90% swing offset, 10% right behind the player)
    "follow_lerp": 0.002,
    // The velocity Steve has to travel in order for the camera to try and swing behind him
    "follow_velocity": 0.1,
    // The delay in seconds before the camera attempts to swing behind the player after some movement AND the right stick is released
    "follow_delay": 0.5,

    //This controls whether the left stick allows the player to move a placement cursor around when holding a structure
    "follow_structure_placement": true
  },

