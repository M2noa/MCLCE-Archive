    //This is the downward angle of the camera.
    "pitch": 90,

    //This is the downard angle that Steve faces in the "Badger Follow" and "Badger Orbit" cameras.
    "head_pitch": 35.0,

    //This is the FOV that this camera will use (overrides the default value)
    "fov": 80.0,

    //This controls how quickly the fixed camera rotates (percentage rotation per tick, ie. 0.1 == 10% rotation per tick)
