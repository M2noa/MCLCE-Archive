{
  "namespace": "xbl_first_launch",

  "splash_text": {
    "type": "custom",
    "renderer": "splash_text_renderer",
    "size": [ 0.1, 0.1 ],
    "layer": 2,
    "anchor_from": "bottom_right",
    "anchor_to": "bottom_right"
  },

  "title_panel_pocket": {
    "type": "panel",
    "offset": [ 0, "10%" ],
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "size": [ "100%", "12.5%x" ],
    "controls": [
      {
        "title_image": {
          "type": "image",
          "layer": 1,
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "texture": "gui/title.png",
          "uv": [ 0, 0 ],
          "uv_size": [ 512, 64 ]
        }
      },
      {
        "@splash_text": {
          "offset": [ "-28%", "-4%x" ]
        }
      }
    ]
  },

  "Xbox_icon": {
    "type": "image",
    "texture": "gui/newgui/xbox4.png",
    "layer": 3,
    "uv": [ 0, 0 ],
    "uv_size": [ 27, 27 ],
    "size": [ 20, 20 ]
  },

  "xbl_signin_label": {
    "type": "panel",
    "layer": 2,
    "controls": [
      {
        "@Xbox_icon": {
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "offset": [24, 0]
        }
      },
      {
        "@common.new_button_label": {
          "text": "xbox.signin"
        }
      }
    ]
  },

  "notnow_label@common.new_button_label": {
    "text": "xbox.notnow"
  },

  "xbl_signin_button@common.new_button": {
    "$pressed_button_name": "button.xbl_signin",
    "controls": [
      {
        "default@common.new_button_state_default": {
          "controls": [
            {
              "@xbl_first_launch.xbl_signin_label": { }
            }
          ]
        }
      },
      {
        "hover@common.new_button_state_hover": {
          "controls": [
            {
              "@xbl_first_launch.xbl_signin_label": { }
            }
          ]
        }
      },
      {
        "pressed@common.new_button_state_pressed": {
          "controls": [
            {
              "@xbl_first_launch.xbl_signin_label": {
                "offset": [ 0, 1 ]
              }
            }
          ]
        }
      }
    ]
  },

  "notnow_button@common.new_button": {
    "$pressed_button_name": "button.xbl_notnow",
    "controls": [
      {
        "default@common.new_button_state_default": {
          "controls": [
            {
              "@xbl_first_launch.notnow_label": { }
            }
          ]
        }
      },
      {
        "hover@common.new_button_state_hover": {
          "controls": [
            {
              "@xbl_first_launch.notnow_label": { }
            }
          ]
        }
      },
      {
        "pressed@common.new_button_state_pressed": {
          "controls": [
            {
              "@xbl_first_launch.notnow_label": {
                "offset": [ 0, 1 ]
              }
            }
          ]
        }
      }
    ]
  },

  "title_image_panel": {
    "type": "panel",
    "controls": [
      {
        "title_image": {
          "type": "image",
          "layer": 1,
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "texture": "gui/newgui/train.jpg",
          "offset": [ 2, 2 ],
          "size": [ "109.876%y", "100%" ],
          "uv_size": [ 267, 243 ]
        }
      },
      {
        "message_label": {
          "type": "label",
          "size": [ "100%-109.876%y-4px", "100%" ],
          "anchor_from": "right_middle",
          "anchor_to": "right_middle",
          "offset": [0, 2],
          "alignment": "top_middle",
          "wrap": true,
          "clip": true,
          "text": "#message",
          "layer": 2,
          "color": [ 1,1,1 ],
          "bindings": [
            {
              "binding_name": "#message"
            }
          ]
        }
      }
    ]
  },

  "main_panel": {
    "type": "input_panel",
    "size": "$xbl_first_launch_screen_size",
    "offset": [0, "15%"],
    "controls": [
      {
        "@common.common_panel": {
          "$dialog_background": "dialog_background_hollow_4",
          "$show_close_button": false
        }
      },
      {
        "myimage@title_image_panel": {
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "size": [ "100%-16px", "100%-52px" ],
          "offset": [ 8, 8 ]
        }
      },
      {
        "a@xbl_signin_button": {
          "size": [ "50%-10px", 30 ],
          "anchor_from": "bottom_right",
          "anchor_to": "bottom_right",
          "offset": [ -10, -10 ]
        }
      },
      {
        "a@notnow_button": {
          "size": [ "50%-10px", 30 ],
          "anchor_from": "bottom_left",
          "anchor_to": "bottom_left",
          "offset": [ 10, -10 ]
        }
      }
    ]
  },

  "gamepad_helpers": {
    "type": "panel",
    "layer": 2,
    "controls": [
      {
        "@common.gamepad_helper_a": {
          "size": [ 30, 10 ],
          "offset": [ -70, -2 ],
          "anchor_from": "bottom_right",
          "anchor_to": "bottom_right"
        }
      }
    ]
  },

  // -----------------------------------------------
  //
  //    screen
  //
  // -----------------------------------------------
  "xbl_first_launch_screen@common.base_screen": {
    "button_mappings": [
      {
        "from_button_id": "button.menu_cancel",
        "to_button_id": "button.menu_exit",
        "mapping_type": "global"
      },
      {
        "from_button_id": "button.menu_up",
        "to_button_id": "button.menu_up",
        "mapping_type": "global",
        "scope": "view"
      },
      {
        "from_button_id": "button.menu_down",
        "to_button_id": "button.menu_down",
        "mapping_type": "global",
        "scope": "view"
      },
      {
        "from_button_id": "button.menu_left",
        "to_button_id": "button.menu_left",
        "mapping_type": "global",
        "scope": "view"
      },
      {
        "from_button_id": "button.menu_right",
        "to_button_id": "button.menu_right",
        "mapping_type": "global",
        "scope": "view"
      }
    ],
    "$screen_content": "xbl_first_launch.xbl_first_launch_screen_content"
  },

  "xbl_first_launch_screen_content": {
    "type": "panel",
    "controls": [
      {
        "@title_panel_pocket": { }
      },
      {
        "root_panel": {
          "type": "panel",
          "controls": [
            { "@gamepad_helpers": { } },
            { "@main_panel": { "layer": 1 } }
          ]
        }
      }
    ]
  }
}
